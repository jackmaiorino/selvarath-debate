# The nine code-provenance frozen files are hash-bound into Phase 2 execution manifests
# (phase2_execution.CODE_PROVENANCE_FROZEN_FILES). Their working-tree bytes must equal the
# committed git blobs byte-for-byte, so core.autocrlf smudging must never rewrite them.
# Scope is deliberately restricted to exactly these files: other files (notably uv.lock,
# whose raw hash is also manifest-bound) keep their current working-tree byte state.
rejudge/phase2_preflight_runner.py text eol=lf
rejudge/api_client.py text eol=lf
rejudge/phase2_execution.py text eol=lf
rejudge/phase2_role_limits.py text eol=lf
rejudge/phase2_capability_corpus.py text eol=lf
rejudge/phase2_prompt_bundle.py text eol=lf
rejudge/phase2_plan.py text eol=lf
rejudge/runner.py text eol=lf
rejudge/run_manifest.py text eol=lf
